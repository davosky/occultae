<tr id="<%= dom_id user %>">
  <td>
    <%= link_to user do %>
      <i class="fa-solid fa-circle-user"></i>
      &nbsp;<%= user.username %>
    <% end %>
  </td>
  <td><%= user.first_name %></td>
  <td><%= user.last_name %></td>
  <td><%= user.category %></td>
  <td><%= user.region %></td>
  <td><%= user.province %></td>
  <td>
    <%= link_to edit_user_path(user), 
            "data-bs-toggle": "tooltip", 
            "title": "Modifica il Record Corrente", class: "text-warning" do %>
      <i class="fa-solid fa-pen"></i>
    <% end %>
  </td>
  <td>
    <%= link_to confirm_delete_user_path(user), 
    "data-bs-toggle": "tooltip", 
    "title": "Elimina il Record Corrente",
    class: "text-danger" do %>
      <i class="fa-solid fa-trash-can"></i>
    <% end %>
  </td>
</tr>
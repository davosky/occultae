<div class="row p-3" data-controller="modal-select">
  <!-- Modal -->
  <div class="modal fade" id="groupsModal" tabindex="-1"
       data-action="shown.bs.modal->modal-select#groupsModalOpened">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">
            <%= image_tag("groups/groups-logo.svg", class: "img-fluid", size: "52x52", alt: "groups-logo") %>
            &emsp;
            Seleziona Gruppi
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal">&#10006;</button>
        </div>
        <div class="modal-body">
          <input type="text"
                 class="form-control mb-3"
                 placeholder="Cerca gruppo..."
                 data-modal-select-target="groupSearch"
                 data-action="input->modal-select#filterGroups">
          <div class="row">
            <% Group.order(:name).each do |group| %>
              <div class="col-4"
                   data-modal-select-target="groupItem"
                   data-name="<%= group.name.downcase %>">
                <div class="form-check">
                  <input type="checkbox"
                         class="form-check-input"
                         id="group_<%= group.id %>"
                         value="<%= group.id %>"
                         <%= user.group_ids.include?(group.id) ? "checked" : "" %>
                         data-modal-select-target="groupCheckbox"
                         data-name="<%= group.name %>"
                         data-action="change->modal-select#updateGroupsCount">
                  <%= label_tag "group_#{group.id}", group.name, class: "form-check-label" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
        <div class="modal-footer justify-content-between">
          <small class="text-muted" data-modal-select-target="groupsCount"></small>
          <button type="button" class="btn btn-primary"
        data-bs-dismiss="modal"
        data-action="click->modal-select#confirmGroups">
            <i class="fa-solid fa-circle-check"></i>&emsp;Conferma
          </button>
        </div>
      </div>
    </div>
  </div>
  <%= form_with(model: user) do |form| %>
    <% if user.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(user.errors.count, "errori") %> hanno impedito il salvataggio dati:</h2>
        <ul>
          <% user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <div class="row mb-3">
      <div class="col-6">
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-circle-user"></i>&emsp;<%= form.label :username %>
          </span>
          <%= form.text_field :username, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-at"></i>&emsp;<%= form.label :email %>
          </span>
          <%= form.text_field :email, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-key"></i>&emsp;<%= form.label :password %>
          </span>
          <%= form.text_field :password, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-user"></i>&emsp;<%= form.label :first_name %>
          </span>
          <%= form.text_field :first_name, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-user-group"></i>&emsp;<%= form.label :last_name %>
          </span>
          <%= form.text_field :last_name, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-mars-and-venus"></i>&emsp;<%= form.label :gender %>
          </span>
          <%= form.text_field :gender, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-id-badge"></i>&emsp;<%= form.label :fiscal_code %>
          </span>
          <%= form.text_field :fiscal_code, class: 'form-control' %>
        </div>
      </div>
      <div class="col-6">
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-calendar-day"></i>&emsp;<%= form.label :birth_date %>
          </span>
          <%= form.date_field :birth_date, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-city"></i>&emsp;<%= form.label :birth_place %>
          </span>
          <%= form.text_field :birth_place, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-square"></i>&emsp;<%= form.label :category %>
          </span>
          <%= form.text_field :category, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-location-pin"></i>&emsp;<%= form.label :region %>
          </span>
          <%= form.text_field :region, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-location-dot"></i>&emsp;<%= form.label :province %>
          </span>
          <%= form.text_field :province, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-building"></i>&emsp;<%= form.label :institute %>
          </span>
          <%= form.text_field :institute, class: 'form-control' %>
        </div>
        <div class="input-group mb-1">
          <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
            <i class="fa-solid fa-building-user"></i>&emsp;<%= form.label :office %>
          </span>
          <%= form.text_field :office, class: 'form-control' %>
        </div>
      </div>
    </div>
    <%# Gruppi selector %>
    <hr/>
    <h4 class="<%= form_texts_class %>">Gruppi</h4>
    <div class="row mt-3">
      <div class="input-group mb-1">
        <span class="input-group-text input-group-text-fixed <%= form_elements_class %>">
          <i class="fa-solid fa-users"></i>&emsp;<%= form.label :groups %>
        </span>
        <div class="form-control d-flex align-items-center justify-content-between">
          <span data-modal-select-target="groupsSummary" class="text-muted fst-italic">
            <%= user.groups.any? ? user.groups.map(&:name).join(", ") : "Nessun gruppo selezionato" %>
          </span>
          <button type="button" class="btn btn-sm btn-outline-primary"
                  data-bs-toggle="modal"
                  data-bs-target="#groupsModal">
            <i class="fa-solid fa-square-check"></i>&emsp;Seleziona
          </button>
        </div>
      </div>
    </div>
    <%# Hidden fields per group_ids %>
    <div id="group-hidden-fields">
      <%= hidden_field_tag "user[group_ids][]", "" %>
      <% user.group_ids.each do |gid| %>
        <%= hidden_field_tag "user[group_ids][]", gid %>
      <% end %>
    </div>
    <hr/>
    <div class="row">
      <div class="col-2">
        <div class="d-grid">
          <%= submit_tag submit_button_text, class: submit_button %>
        </div>
      </div>
      <div class="col-2">
        <div class="d-grid">
          <%= link_to users_path, class: "btn btn-secondary" do %>
            Annulla
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
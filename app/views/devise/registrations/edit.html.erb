<div class="row mt-3">
  <div class="col-6 offset-3 p-5 bg-light border">
    <h4 class="text-primary fw-bold">
      <%= supervisor_avatar %>
      &nbsp;
      <%= "#{current_supervisor.first_name} #{current_supervisor.last_name}".html_safe %>
    </h4>
    <hr class="text-primary mb-3"/>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div class="field">
        <%= f.label :password, class: "text-primary" %> <i>(lascia vuoto se non vuoi modificarla)</i><br />
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
        <% if @minimum_password_length %>
          <em>minimo caratteri:&nbsp;<%= @minimum_password_length %></em>
        <% end %>
      </div>
      <div class="field mt-2">
        <%= f.label :password_confirmation, class: "text-primary" %><br />
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
      </div>
      <div class="field mt-2">
        <%= f.label :current_password, class: "text-primary" %> <i>(abbiamo bisogno della tua password attuale per confermare le modifiche)</i><br />
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
      </div>
      <div class="d-grid mb-1 mt-2">
        <%= button_tag(type: "submit", class: "btn btn-primary mt-3") do %>
          <i class="fa-solid fa-arrow-right-to-bracket"></i>&nbsp;Aggiorna
        <% end %>
      </div>
    <% end %>
  </div>
</div>

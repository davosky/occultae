<div class="col-12">
  <p class="ps-3">
    <%= image_tag "groups/groups-logo.svg", class: "ms-3", size: "48x48" %>
    &emsp; <span class="fs-3 fw-bold text-primary">
      <%= "#{@group&.name}".html_safe %>
    </span>
    <span class="float-end">
      <%= link_to groups_path, class: "btn btn-light" do %>
        <i class="fa-regular fa-circle-xmark"></i>&emsp;Chiudi
      <% end %>
    </span>
  </p>
  <div class="card bg-white border pt-3 pb-3 ps-4 pe-4">
    <div class="row">
      <div class="col-6 bg-white">
        <h4 class="text-primary">
          <%= image_tag "users/users-logo.svg", class: "ms-3", size: "36x36" %>
          &emsp;
          Utenti appartenenti al Gruppo
        </h4>
        <hr/>
        <table class="table table-striped table-hover">
          <thead>
            <tr>
              <th class="text-secondary">
                <i class="fa-solid fa-circle-user"></i>&emsp;Nome Utente
              </th>
              <th class="text-secondary">
                <i class="fa-solid fa-users"></i>&emsp;Nome e Cognome
              </th>
              <th class="text-secondary">
                <i class="fa-solid fa-square"></i>&emsp;Categoria
              </th>
              <th class="text-secondary">
                <i class="fa-solid fa-location-pin"></i>&emsp;Regione
              </th>
              <th class="text-secondary">
                <i class="fa-solid fa-location-dot"></i>&emsp;Provincia
              </th>
            </tr>
          </thead>
          <tbody>
            <% @group.users.each do |user| %>
              <tr>
                <td>
                  <%= link_to user do %>
                    <i class="fa-solid fa-circle-user"></i>&emsp;<%= user.username %>
                  <% end %>
                </td>
                <td><%= "#{user.first_name} #{user.last_name}".html_safe %></td>
                <td><%= user.category %></td>
                <td><%= user.region %></td>
                <td><%= user.province %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="col-6 bg-white border-start">
        <h4 class="text-primary">
          <%= image_tag "nodes/nodes-logo.svg", class: "ms-3", size: "36x36" %>
          &emsp;
          Nodi a cui il gruppo &egrave; stato assegnato
        </h4>
        <hr/>
        <table class="table table-striped table-hover">
          <thead>
            <tr>
              <th class="text-secondary">
                <i class="fa-solid fa-folder-tree"></i>&emsp;Nodo SinCGIL
              </th>
            </tr>
          </thead>
          <tbody>
            <% @group.nodes.reorder(:ancestry_depth, :name).each do |node| %>
              <tr>
                <td>
                  <%= link_to node do %>
                    <span style="padding-left: <%= node.depth * 1.5 %>rem">
                      <i class="fa-solid fa-folder"></i>&emsp;<%= node.name %>
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    <hr/>
    <div class="row">
      <div class="col-12">
        <h4 class="text-primary">
          <%= image_tag "features/features-logo.svg", class: "ms-3", size: "36x36" %>
          &emsp;
          Attributi e voci per nodo, come Gruppo
        </h4>
        <br/>
        <% @group.nodes.order(:ancestry_depth, :name).each do |node| %>
          <div class="mb-4">
            <h5 class="text-primary">
              <i class="fa-solid fa-folder"></i>&emsp;<%= link_to node.name, node %>
            </h5>
            <% if node.features.any? %>
              <% node.features.each do |feature| %>
                <div class="ms-4 mb-3">
                  <h6 class="text-info">
                    <i class="fa-solid fa-list"></i>&emsp;<%= link_to feature.name, feature %>
                    <span class="text-secondary fst-italic ms-2">(<%= feature.grouping %>)</span>
                  </h6>
                  <% if feature.voices.any? %>
                    <table class="table table-hover">
                      <thead>
                        <tr>
                          <th class="text-secondary"><i class="fa-solid fa-cubes"></i>&emsp;Raggruppamento</th>
                          <th class="text-secondary"><i class="fa-regular fa-rectangle-list"></i>&emsp;Voce</th>
                          <th class="text-secondary"><i class="fa-solid fa-stop"></i>&emsp;Tipo</th>
                          <th class="text-secondary"><i class="fa-regular fa-square"></i>&emsp;Valore</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% feature.voices.order(:grouping, :name).each do |voice| %>
                          <tr>
                            <td class="text-secondary"><%= voice.grouping %></td>
                            <td class="text-info fw-bold"><%= voice.name %></td>
                            <td class="text-secondary"><%= voice.value_type %></td>
                            <td><%= value_type_image(voice) %></td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  <% else %>
                    <p class="text-muted ms-4 fst-italic">Nessuna voce presente</p>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <p class="text-muted ms-4 fst-italic">Nessun attributo presente</p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
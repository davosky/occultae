<div class="col-12">
  <p class="ps-3">
    <%= image_tag "nodes/nodes-logo.svg", class: "ms-3", size: "48x48" %>
    &emsp; <span class="fs-3 fw-bold text-primary">
      <%= "#{@node&.name}".html_safe %>
    </span>
    <span class="float-end">
      <%= link_to edit_node_path(@node), class: "btn btn-warning me-3" do %>
        <i class="fa-solid fa-pencil"></i>
        <i class="fa-solid fa-folder-tree"></i>
        &emsp;
        Modifica questo Nodo
      <% end %>
      &emsp;
      <%= link_to confirm_delete_node_path(@node), "data-bs-toggle": "tooltip", "title": "Elimina il Record Corrente", class: "btn btn-danger" do %>
        <i class="fa-solid fa-trash-can"></i>
        <i class="fa-solid fa-folder-tree"></i>
        &emsp;
        Elimina questo Nodo
      <% end %>
      &emsp;
      <%= link_to nodes_path, class: "btn btn-light me-3" do %>
        <i class="fa-regular fa-circle-xmark"></i>
        &emsp;
        Chiudi
      <% end %>
    </span>
  </p>
  <div class="card bg-white border pt-3 pb-3 ps-4 pe-4">
    <div class="row">
      <div class="col-6">
        <span class="fs-4 fw-bold">
          <i class="fa-solid fa-folder-tree fs-4 fw-bold"></i>&nbsp;Struttura:
        </span>
        <ul class="tree">
          <% @tree.each do |node, children| %>
            <%= render partial: "tree_node", locals: { node: node, children: children } %>
          <% end %>
        </ul>
      </div>
      <div class="col-6">
      </div>
    </div>
  </div>
</div>
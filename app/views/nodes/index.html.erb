<div class="col-12">
  <p>
    <%= image_tag "nodes/nodes-logo.svg", class: "ms-3", size: "48x48" %>
    &emsp; <span class="fs-3 fw-bold text-primary">Nodi</span>
    <span class="float-end">
      <%= link_to new_node_path, class: "btn btn-success me-3" do %>
        <i class="fa-solid fa-plus"></i>
        <i class="fa-solid fa-folder-tree"></i>
        &emsp;
        Inserisci un nuovo Nodo
      <% end %>
    </span>
  </p>
  <div class="card bg-white border mt-3 p-3">
    <div class="row">
      <div class="col-8 offset-2 node-tree">
        <ul class="tree-root">
          <% @tree.each do |node, children| %>
            <%= render "tree_node_index", node: node, children: children %>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>